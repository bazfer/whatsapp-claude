# Copy to .env and fill in values before running ./install.sh.

# How often to poll the WhatsApp DB (seconds)
POLL_INTERVAL_SECONDS=10

# Number of prior messages to include in the Claude prompt for context
HISTORY_MESSAGES=10

# Absolute path to this repo root. CLAUDE.md lives here.
BOT_WORKING_DIR=/home/deet/whatsapp-claude

# SQLite DB written by the whatsapp-bridge service.
WA_DB_PATH=/home/deet/whatsapp-claude/store/messages.db

# Poller persisted state path.
STATE_PATH=/home/deet/whatsapp-claude/state.json

# Timeout for each `claude -p` invocation (seconds)
CLAUDE_TIMEOUT_SECONDS=60

# WhatsApp bridge REST API port and MCP server target URL.
WHATSAPP_BRIDGE_PORT=8080
WHATSAPP_API_URL=http://127.0.0.1:8080/api
