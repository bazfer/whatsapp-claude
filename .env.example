# Copy to .env and fill in values before running.

# How often to poll the WhatsApp DB (seconds)
POLL_INTERVAL_SECONDS=10

# Number of prior messages to include in the Claude prompt for context
HISTORY_MESSAGES=10

# Absolute path to the directory that contains CLAUDE.md (this repo root).
# `claude -p` is run with this as the working directory so it picks up CLAUDE.md.
BOT_WORKING_DIR=/home/deet/whatsapp-claude

# Path to the SQLite DB written by the whatsapp-bridge Go service.
# Relative to whatsapp-mcp project: whatsapp-bridge/store/messages.db
WA_DB_PATH=/home/deet/whatsapp-mcp/whatsapp-bridge/store/messages.db

# Where poller persists its watermark and sent-message IDs.
STATE_PATH=/home/deet/whatsapp-claude/state.json

# Timeout for each `claude -p` invocation (seconds). Default: 60.
CLAUDE_TIMEOUT_SECONDS=60
